# CyberSentinel Environment Configuration
# Copy this file to .env and fill in your API keys.
# NEVER commit .env to version control.

# ---------------------------------------------------------------------------
# LLM Settings
# ---------------------------------------------------------------------------

# Set to false to use the real Anthropic API (requires ANTHROPIC_API_KEY below)
# Default: true — all LLM calls return instant mock responses, no API key needed
USE_MOCK_LLM=true

# Required when USE_MOCK_LLM=false
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Model selection (used when USE_MOCK_LLM=false)
ORCHESTRATOR_MODEL=claude-opus-4-6
SUBAGENT_MODEL=claude-sonnet-4-6

# Simulated latency for mock mode (milliseconds)
MOCK_DELAY_MS=200

# ---------------------------------------------------------------------------
# LLM Retry and Token Budget (Phase 4)
# ---------------------------------------------------------------------------

# Number of retries on rate limit or API errors
LLM_MAX_RETRIES=3

# Base delay in seconds for exponential backoff (doubles each retry)
LLM_RETRY_BASE_DELAY=2.0

# Per-agent max token limits for each LLM call
ORCHESTRATOR_MAX_TOKENS=2048
VULN_AGENT_MAX_TOKENS=1024
THREAT_AGENT_MAX_TOKENS=1024
LOG_AGENT_MAX_TOKENS=2048
REPORT_AGENT_MAX_TOKENS=4096

# Cost warning threshold in USD (logs a warning when a single call exceeds this)
COST_WARNING_THRESHOLD=1.00

# ---------------------------------------------------------------------------
# NVD (National Vulnerability Database)
# ---------------------------------------------------------------------------
# Optional — increases rate limit from 5 to 50 req/30s
NVD_API_KEY=

# ---------------------------------------------------------------------------
# AbuseIPDB (Phase 2)
# ---------------------------------------------------------------------------
# Get your key at: https://www.abuseipdb.com/api
ABUSEIPDB_API_KEY=

# ---------------------------------------------------------------------------
# AlienVault OTX (Phase 2)
# ---------------------------------------------------------------------------
# Get your key at: https://otx.alienvault.com/api
OTX_API_KEY=

# ---------------------------------------------------------------------------
# VirusTotal (Phase 5)
# ---------------------------------------------------------------------------
VT_API_KEY=

# ---------------------------------------------------------------------------
# Shodan (Phase 5)
# ---------------------------------------------------------------------------
SHODAN_API_KEY=

# ---------------------------------------------------------------------------
# Exa (Web Search Intelligence)
# ---------------------------------------------------------------------------
# Enriches CVE lookups with real-time advisories, write-ups, and PoC intel
# Get your key at: https://exa.ai
EXA_API_KEY=
EXA_SEARCH_TYPE=auto
EXA_NUM_RESULTS=5

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
DB_PATH=cybersentinel.db

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
LOG_FILE=cybersentinel.log
LOG_LEVEL=DEBUG

# ---------------------------------------------------------------------------
# Dashboard
# ---------------------------------------------------------------------------
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8000
DASHBOARD_RELOAD=false
