# CyberSentinel Environment Configuration
# Copy this file to .env and fill in your API keys.
# NEVER commit .env to version control.

# LLM Settings
USE_MOCK_LLM=true
ANTHROPIC_API_KEY=
ORCHESTRATOR_MODEL=claude-opus-4-6
SUBAGENT_MODEL=claude-sonnet-4-6
MOCK_DELAY_MS=200

# NVD (National Vulnerability Database)
# Optional — increases rate limit from 5 to 50 req/30s
NVD_API_KEY=

# AbuseIPDB (Phase 2)
ABUSEIPDB_API_KEY=

# AlienVault OTX (Phase 2)
OTX_API_KEY=

# VirusTotal (Phase 2)
VT_API_KEY=

# Shodan (Phase 2)
SHODAN_API_KEY=

# Database
DB_PATH=cybersentinel.db

# Logging
LOG_FILE=cybersentinel.log
LOG_LEVEL=DEBUG
